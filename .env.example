# Airtable Configuration
# Get your API key: https://airtable.com/create/tokens
# Find your Base ID: In the Airtable URL after airtable.com/

AIRTABLE_API_KEY=pat_your_personal_access_token_here
AIRTABLE_BASE_ID=app_your_base_id_here
AIRTABLE_TABLE_NAME=Products

# Sanity Configuration
# Get your Project ID: sanity.io/manage → Your Project
# Create API Token: sanity.io/manage → Project → API → Tokens → Add API token
#   - Name: "Airtable Publisher"
#   - Permissions: "Editor" (needs write access)

SANITY_PROJECT_ID=your_project_id
SANITY_DATASET=production
SANITY_API_TOKEN=sk_your_write_token_here
